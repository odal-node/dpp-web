---
import Base from "../layouts/Base.astro";

const title = "404 — Odal Node";
const description = "The page you asked for does not exist on odal-node.io.";
---

<Base title={title} description={description} noindex>
  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-xs uppercase tracking-widest text-primary-500 font-semibold mb-4">404</p>
    <h1 class="text-4xl font-bold mb-4 text-neutral-900">
      Page not found.
    </h1>
    <p class="text-neutral-600 leading-body mb-8">
      The page you asked for does not exist on this site. It might have moved, or
      it might never have been here.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/"
        class="inline-block px-6 py-3 bg-primary-800 hover:bg-primary-900 text-white rounded-md font-medium no-underline"
      >
        Back to home
      </a>
      <a
        href="https://docs.odal-node.io"
        class="inline-block px-6 py-3 border border-neutral-300 rounded-md font-medium no-underline hover:border-primary-500"
      >
        Read the docs
      </a>
    </div>
  </section>
</Base>
