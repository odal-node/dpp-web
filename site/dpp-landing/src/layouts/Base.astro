---
// Base.astro — shared layout for every landing-site page.
// Wraps page content with the global stylesheet, meta tags, nav, and footer.
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Override the canonical URL if the page is reached at more than one path. */
  canonical?: string;
  /** Additional JSON-LD structured data blocks (array of objects). */
  jsonLd?: Record<string, unknown>[];
  /** Set true on error pages (404) to add noindex. */
  noindex?: boolean;
}

const { title, description, canonical, jsonLd = [], noindex = false } = Astro.props;
const canonicalHref = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og-image.png", Astro.site).toString();

// Base structured data — present on every page.
const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Odal Node",
  url: "https://odal-node.io",
  logo: new URL("/favicon.svg", Astro.site).toString(),
  description:
    "Open-source infrastructure for EU Digital Product Passports under the Ecodesign for Sustainable Products Regulation (ESPR).",
  sameAs: ["https://github.com/odal-node"],
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Odal Node",
  url: "https://odal-node.io",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalHref} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#080C2C" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Odal Node" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col bg-neutral-0 text-neutral-900">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-60 focus:px-3 focus:py-2 focus:bg-primary-500 focus:text-white focus:rounded-md"
    >
      Skip to content
    </a>

    <Nav />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
